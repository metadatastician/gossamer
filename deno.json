{
  "name": "@hyperpolymath/gossamer",
  "version": "0.3.1",
  "tasks": {
    "test": "deno test --allow-env tests/",
    "test:unit": "deno test --allow-env tests/unit/",
    "test:property": "deno test --allow-env tests/property/",
    "test:e2e": "deno test --allow-env tests/e2e/",
    "test:aspect": "deno test --allow-env tests/aspect/",
    "test:bench": "deno bench --allow-env tests/bench/"
  },
  "lint": {
    "rules": {
      "exclude": []
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  }
}
