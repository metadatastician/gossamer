package io.gossamer;

import android.app.Notification;
import android.app.NotificationChannel;
import android.app.NotificationManager;
import android.app.Service;
import android.content.Intent;
import android.content.pm.ServiceInfo;
import android.os.Build;
import android.os.IBinder;

/**
 * GossamerService — native-driven foreground Service.
 *
 * The JVM owns the lifecycle; each callback is forwarded to a native handler
 * (registered by the app via gossamer_service_bind) which returns a directive
 * this class applies. See android_service.zig for the native side and the
 * directive grammar.
 *
 *   onCreate       -> nativeOnCreate()
 *   onStartCommand -> nativeOnStartCommand(action, flags, startId)  [foreground + sticky]
 *   onDestroy      -> nativeOnDestroy()
 *
 * Directive (one "key\tvalue" per line): foreground, channelId, channelName,
 * title, text, fgType (dataSync|location|connectedDevice|none), sticky.
 */
public class GossamerService extends Service {

    static {
        System.loadLibrary("gossamer");
    }

    private native String nativeOnCreate();
    private native String nativeOnStartCommand(String action, int flags, int startId);
    private native void nativeOnDestroy();

    private static final int NOTIF_ID = 0x0607; // 'g' marker

    @Override
    public void onCreate() {
        super.onCreate();
        apply(nativeOnCreate());
    }

    @Override
    public int onStartCommand(Intent intent, int flags, int startId) {
        String action = (intent != null) ? intent.getAction() : null;
        boolean sticky = apply(nativeOnStartCommand(action, flags, startId));
        return sticky ? START_STICKY : START_NOT_STICKY;
    }

    @Override
    public void onDestroy() {
        nativeOnDestroy();
        super.onDestroy();
    }

    @Override
    public IBinder onBind(Intent intent) {
        return null;
    }

    /** Apply a directive; returns whether START_STICKY was requested. */
    private boolean apply(String directive) {
        if (directive == null || directive.isEmpty()) {
            return false;
        }
        String channelId = "gossamer";
        String channelName = "Gossamer";
        String title = "";
        String text = "";
        String fgType = "none";
        boolean foreground = false;
        boolean sticky = false;

        for (String line : directive.split("\n")) {
            int tab = line.indexOf('\t');
            if (tab < 0) {
                continue;
            }
            String key = line.substring(0, tab);
            String value = line.substring(tab + 1);
            switch (key) {
                case "foreground":  foreground = value.equals("1"); break;
                case "channelId":   channelId = value; break;
                case "channelName": channelName = value; break;
                case "title":       title = value; break;
                case "text":        text = value; break;
                case "fgType":      fgType = value; break;
                case "sticky":      sticky = value.equals("1"); break;
                default: break;
            }
        }

        if (foreground) {
            startForegroundWith(channelId, channelName, title, text, fgType);
        }
        return sticky;
    }

    private void startForegroundWith(String channelId, String channelName, String title, String text, String fgType) {
        NotificationManager nm = getSystemService(NotificationManager.class);
        if (nm != null && nm.getNotificationChannel(channelId) == null) {
            nm.createNotificationChannel(
                new NotificationChannel(channelId, channelName, NotificationManager.IMPORTANCE_LOW));
        }
        Notification notif = new Notification.Builder(this, channelId)
            .setContentTitle(title)
            .setContentText(text)
            .setSmallIcon(android.R.drawable.stat_notify_sync)
            .setOngoing(true)
            .build();
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.UPSIDE_DOWN_CAKE) {
            startForeground(NOTIF_ID, notif, foregroundTypeFlag(fgType));
        } else {
            startForeground(NOTIF_ID, notif);
        }
    }

    private static int foregroundTypeFlag(String fgType) {
        switch (fgType) {
            case "dataSync":        return ServiceInfo.FOREGROUND_SERVICE_TYPE_DATA_SYNC;
            case "location":        return ServiceInfo.FOREGROUND_SERVICE_TYPE_LOCATION;
            case "connectedDevice": return ServiceInfo.FOREGROUND_SERVICE_TYPE_CONNECTED_DEVICE;
            default:                return ServiceInfo.FOREGROUND_SERVICE_TYPE_DATA_SYNC;
        }
    }
}
