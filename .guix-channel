;;
;; Guix channel definition for gossamer
;;
;; To use this channel, add to ~/.config/guix/channels.scm:
;;
;;   (channel
;;     (name 'gossamer)
;;     (url "https://github.com/metadatastician/gossamer")
;;     (branch "main"))
;;
;; Then: guix pull

(channel
  (version 0)
  (url "https://github.com/metadatastician/gossamer")
  (dependencies
   (channel
     (name 'guix)
     (url "https://git.savannah.gnu.org/git/guix.git")
     (branch "master"))))
