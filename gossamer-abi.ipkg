--
-- Gossamer ABI — Idris2 package for type-checking the formal ABI proofs.
--
-- Includes the core Gossamer webview ABI (Types, Layout, Foreign) and
-- the Groove protocol for type-safe inter-service discovery.
--
-- Build:   idris2 --build gossamer-abi.ipkg
-- Check:   idris2 --typecheck gossamer-abi.ipkg

package gossamer-abi

version = 0.1.0

authors = "Jonathan D.A. Jewell"

brief = "Formally verified ABI for the Gossamer webview shell and Groove protocol"

-- Source files live in src/interface/abi/ but declare module Gossamer.ABI.*
-- Symlinks in src/interface/Gossamer/ABI/ map the Idris2 module namespace
-- to the physical file locations.
sourcedir = "src/interface"

depends = base

modules = Gossamer.ABI.Types
        , Gossamer.ABI.Layout
        , Gossamer.ABI.Foreign
        , Gossamer.ABI.Groove
        , Gossamer.ABI.CapabilityAuthenticity
        , Gossamer.ABI.IPCDispatch
        , Gossamer.ABI.HandleLinearity
        , Gossamer.ABI.WindowStateMachine
        , Gossamer.ABI.GrooveTermination

-- DEFERRED (owner design call — Refs standards#131). Syntactic/structural
-- defects were fixed in-tree (parse errors, name clashes, lteRefl, missing
-- coverage), but each module has RESIDUAL proof/design debt that is not a
-- clean discharge. Excluded so the CI gate stays green and the debt stays
-- visible rather than silently bit-rotting:
--   * PanelIsolation / ResourceCleanup — `distinctSym` needs commutativity
--     of primitive String `==`: a sanctioned String-primitive bridge axiom
--     or refactor `Distinct` to carry `Not (a = b)`.
--   * LayoutStability — `So` witnesses (`v030ExtendsV020`,
--     `resultCodesStable`) range over opaque top-level layout constants
--     that do not reduce; needs `choose`-based discharge.
--   * IPCIntegrity — `hashPreservation` is forward-referenced before
--     `VerifiedReceive` and its theorem statement has unbound implicits
--     plus a second `where`-accessor; needs theorem restatement.
--      , Gossamer.ABI.PanelIsolation
--      , Gossamer.ABI.ResourceCleanup
--      , Gossamer.ABI.LayoutStability
--      , Gossamer.ABI.IPCIntegrity
