; SPDX-License-Identifier: MPL-2.0
; SPDX-FileCopyrightText: 2026 Jonathan D.A. Jewell (hyperpolymath)
;
; 0-AI-MANIFEST.a2ml — Universal AI entry point for Gossamer
; Media-Type: application/a2ml

; THIS FILE MUST BE READ FIRST BY ALL AI AGENTS

(manifest
  (identity
    (name "Gossamer")
    (full-name "Gossamer — Linearly-Typed Webview Shell Framework")
    (version "0.3.1")
    (repo "https://github.com/hyperpolymath/gossamer")
    (license "MPL-2.0")
    (author "Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>"))

  (purpose
    "Linearly-typed webview shell framework. Ephapax core with Idris2 ABI
     and Zig FFI. Replaces Tauri across the hyperpolymath ecosystem.
     Linear types enforce resource safety (no GC, no refcounting).
     53 exported FFI functions. Linux/macOS/Windows desktop + iOS/Android mobile.
     173 integration tests. Package distribution: deb/rpm/flatpak/dmg/wix.")

  ;; ===================================================================
  ;; CONTEXT TIERS
  ;; ===================================================================

  (context-tiers
    ; Tier 0 (always load): This file + .claude/CLAUDE.md — orientation only
    ; Tier 1 (load if working on code): README.adoc, EXPLAINME.adoc, Justfile
    ; Tier 2 (load on demand): .machine_readable/*.a2ml, docs/, CHANGELOG.md
    ; Tier 3 (never load unless asked): tests/, generated/, examples/
    ;
    ; DO NOT READ unless specifically asked:
    ;   tests/          — test files (run them, don't read them)
    ;   generated/      — auto-generated code and C headers
    ;   examples/       — example applications
    ;   target/         — build artifacts
    ;   *.lock          — lock files
    )

  ;; ===================================================================
  ;; CANONICAL LOCATIONS
  ;; ===================================================================

  (canonical-locations
    (ai-manifest     "0-AI-MANIFEST.a2ml"           "THIS FILE")
    (ai-instructions ".claude/CLAUDE.md"             "Claude-specific patterns")
    (state           ".machine_readable/descriptiles/STATE.a2ml")
    (meta            ".machine_readable/descriptiles/META.a2ml")
    (ecosystem       ".machine_readable/descriptiles/ECOSYSTEM.a2ml")
    (config          "gossamer.conf.json"            "Gossamer runtime configuration"))

  ;; ===================================================================
  ;; ARCHITECTURE
  ;; ===================================================================

  (architecture
    (layers
      (abi     "src/interface/abi/*.idr"      "Idris2 formal specification")
      (ffi     "src/interface/ffi/src/*.zig"  "Zig C ABI implementation")
      (headers "src/interface/generated/*.h"  "Auto-generated C headers")
      (core    "src/core/*.eph"               "Ephapax core (Shell, Bridge, Capabilities)")
      (platform "src/interface/ffi/src/webview_*.zig" "Platform-specific webview backends (Zig)")
      (bindings "bindings/"                   "Rust + ReScript bindings"))
    (features
      "Sync IPC (channels), Async IPC (worker threads, 256 inflight),
       CSP enforcement, Streaming events, Capability registry (256 slots),
       Dialog allocator, Thread-local error safety"))

  ;; ===================================================================
  ;; CRITICAL INVARIANTS
  ;; ===================================================================

  (critical-invariants
    (rule "WebviewHandle, Channel, Cap are LINEAR — borrow vs consume matters")
    (rule "ABI-FFI alignment: Result codes in Types.idr MUST match Result enum in main.zig")
    (rule "Platform dispatch: compile-time OS switch in Zig — no runtime detection")
    (rule "No GC: regions + linear types only — no Arc/Rc/refcounting")
    (rule "MkCap NOT exported — capabilities only created by framework")
    (rule "MainThreadProof witness required for WebviewHandle creation")
    (rule "Dangerous patterns BANNED: believe_me, assert_total, sorry, Admitted, unsafeCoerce, Obj.magic")
    (rule "SCM files ONLY in .machine_readable/ — never in root"))

  ;; ===================================================================
  ;; SESSION LIFECYCLE
  ;; ===================================================================

  (lifecycle
    (on-enter
      (step "Read THIS file first")
      (step "Read .machine_readable/descriptiles/STATE.a2ml for current status")
      (step "Check ABI-FFI result code alignment if touching interfaces"))

    (on-exit
      (step "Update .machine_readable/descriptiles/STATE.a2ml with progress")
      (step "Verify no orphaned linear resources in new code")))

  (format-meta
    (version "2.1.0")
    (media-type "application/a2ml")
    (created "2026-03-22")
    (last-updated "2026-04-03")
    (maintained-by "Jonathan D.A. Jewell / hyperpolymath")
    (protocol "https://github.com/hyperpolymath/0-ai-gatekeeper-protocol")))
