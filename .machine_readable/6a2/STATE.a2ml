# STATE.a2ml — Project state checkpoint for Gossamer

[metadata]
project = "gossamer"
version = "0.3.1"
last-updated = "2026-06-02"
status = "active"  # active | paused | archived

[project-context]
name = "gossamer"
purpose = "Linearly-typed webview shell with formal ABI proofs — Ephapax backend, Idris2 ABI, Zig FFI. Desktop apps that can't leak resources by design."
completion-percentage = 92

[crg]
grade = "D"           # D | C | B | A
achieved-on = "2026-04-18"
next-target = "C"
notes = "CRG D after 2026-04-18 audit. D→C blocker resolved 2026-04-25: 16 per-directory README.adoc files added (android/ api/ benchmarks/ bindings/ cli/ configs/ contractiles/ deploy/ ffi/ generated/ packaging/ schema/ schemas/ scripts/ site/ tests/). Dogfooding evidence populated 2026-04-18. Pending CI green on README commit to formally claim C."

[dogfooding-status]
# Populated 2026-04-18 against real on-disk integrations. Each entry must
# resolve to a grep-hit in the cited path. See CRG-DOGFOODING-OPPORTUNITIES
# on Desktop for the estate-wide opportunity map.
boj-server-mcp = "2026-04-18 — gossamer-mcp cartridge (289 LOC, Deno mod.js + Idris2 ABI + Zig FFI). POST to GOSSAMER_BACKEND_URL, tools incl. gossamer_create_window. Path: boj-server/cartridges/gossamer-mcp/"
idaptik-migration-target = "2026-04-18 — IDApTIK desktop migration scheduled (Tauri -> Gossamer). See critical-next-actions."

[position]
phase = "testing"  # design | implementation | testing | maintenance | archived
maturity = "alpha"        # experimental | alpha | beta | production | lts

[route-to-mvp]
milestones = [
  { name = "Phase 0: Core Zig FFI (create, load, run, navigate, eval, channel)", completion = 100 },
  { name = "Phase 1: Capability registry + dialog allocator", completion = 100 },
  { name = "Phase 1b: Corrective fixes (clearError, overflow messages, FIFO eviction, c_allocator)", completion = 100 },
  { name = "Phase 2: Async IPC (gossamer_channel_bind_async, 256-slot inflight, worker threads)", completion = 100 },
  { name = "Phase 2b: CSP enforcement (gossamer_set_csp, CLI auto-apply, Rust/ReScript bindings)", completion = 100 },
  { name = "Phase 2c: Streaming IPC (gossamer_emit, g_idle_add, JS/Rust/ReScript bindings)", completion = 100 },
  { name = "Phase 3: Integration tests + hot reload", completion = 100 },
  { name = "Phase 4: macOS and Windows support", completion = 100 },
  { name = "Phase 5: Mobile (iOS and Android)", completion = 82 },
  { name = "Phase 6: Plugin system (dlopen vtable, load/unload/list, liveness check)", completion = 100 },
]

[blockers-and-issues]
# No active blockers

[critical-next-actions]
actions = [
  "arXiv submission: attempt at arxiv.org (cs.PL / cs.SE) using OU .ac.uk email — may bypass endorsement; Zenodo draft 19535676 already published as preprint",
  "IDApTIK desktop migration: replace Tauri with Gossamer for desktop builds (staging decision required)",
  "Android: NDK CI runner to build libgossamer.so per ABI + emulator smoke test of the four handler paths",
  "Android: APK/AAB assembly + signing pipeline (aapt2/d8/r8/apksigner, gradle-free)",
  "Android: settle Ephapax region-calculus modelling of long-lived Service handles (cross-region Service→Widget refs)",
  "App Store packaging, code signing, and notarisation for iOS",
]

[maintenance-status]
last-run-utc = "2026-04-12"
last-report = "docs/reports/maintenance/latest.json"
last-result = "pass"  # unknown | pass | warn | fail
open-warnings = 0
open-failures = 0

[ecosystem]
part-of = ["hyperpolymath framework ecosystem", "PanLL integration"]
depends-on = ["ephapax", "idris2", "zig", "webkitgtk"]

